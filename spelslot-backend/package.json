{
  "name": "spelslot-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nodemon",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "start": "node dist/index.js",
    "import:lk": "tsx src/scripts/importLk.ts",
    "import:monsters": "tsx src/scripts/importMonsters.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint-check": "eslint .",
    "format": "prettier --write .",
    "test": "npm run type-check && npm run lint-check && vitest run --coverage",
    "test:watch": "vitest",
    "test:run": "vitest run",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@hocuspocus/server": "^3.4.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.0.1",
    "firebase-admin": "^13.10.0",
    "fractional-indexing": "^3.2.0",
    "mongoose": "^8.9.0",
    "multer": "^2.2.0",
    "slugify": "^1.6.9",
    "yjs": "^13.6.31"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.9",
    "nodemon": "^3.1.7",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.1.9"
  }
}
