{
  "name": "spelslot-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --build --force",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint-check": "eslint .",
    "format": "prettier --write .",
    "test": "npm run build && npm run lint-check && vitest run --coverage",
    "test:watch": "vitest",
    "test:run": "vitest run",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@hocuspocus/provider": "^4.3.0",
    "@primevue/themes": "^4.2.5",
    "@tiptap/core": "^3.27.1",
