    "@vitest/coverage-v8": "^4.1.9",
    "@vue/test-utils": "^2.4.11",
    "jsdom": "^29.1.1",
    "typescript": "^5.7.3",
    "vite": "^6.0.11",
    "vite-plugin-checker": "^0.14.4",
